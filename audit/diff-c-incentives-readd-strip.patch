+              "required": [
+                "denom"
+              ],
+              "properties": {
+                "denom": {
+                  "type": "string"
+                }
+              },
+              "additionalProperties": false
+            }
+          },
+          "additionalProperties": false
+        }
+      ]
+    },
+    "InputSchedule": {
+      "description": "External incentive schedule input. Schedules align to weekly epochs (Mondays UTC); `duration_periods` is the number of full weeks the schedule spans. Valid range: 1..=25 (1 week to ~6 months).",
