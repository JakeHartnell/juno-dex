+fn to_camel_case(s: &str) -> String {
+    let mut out = String::with_capacity(s.len());
+    let mut prev_upper = true;
+    for ch in s.chars() {
+        if ch.is_uppercase() {
+            if !prev_upper && !out.is_empty() {
+                out.push('_');
+            }
+            out.push(ch.to_ascii_lowercase());
+            prev_upper = true;
+        } else {
+            out.push(ch);
+            prev_upper = false;
+        }
+    }
+    out
